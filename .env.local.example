# Supabase — copy this file to .env.local and fill in from your project's
# Settings → API page. Both are safe to expose to the browser (the anon key is
# protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# DEMO MODE — set to true to bypass Supabase auth + DB entirely and run the whole
# front-end on in-memory placeholder data (no account needed). Leave false/unset
# for the real backend. The two Supabase values above can be blank when this is true.
NEXT_PUBLIC_DEMO_MODE=false
